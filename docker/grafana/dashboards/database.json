{
    "uid": "db-dashboard",
    "title": "B. Database Performance Dashboard",
    "tags": [
        "hackathon",
        "database"
    ],
    "timezone": "browser",
    "refresh": "10s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "panels": [
        {
            "id": 1,
            "title": "MySQL Up",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 4,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DOWN",
                                    "color": "red"
                                },
                                "1": {
                                    "text": "UP",
                                    "color": "green"
                                }
                            }
                        }
                    ]
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "mysql_up",
                    "legendFormat": "MySQL",
                    "instant": true
                }
            ]
        },
        {
            "id": 2,
            "title": "DB Query Duration (avg)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 4
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(app_db_query_duration_seconds_sum[1m]) / rate(app_db_query_duration_seconds_count[1m])",
                    "legendFormat": "avg query duration"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, rate(app_db_query_duration_seconds_bucket[1m]))",
                    "legendFormat": "p95 query duration"
                }
            ]
        },
        {
            "id": 3,
            "title": "DB Queries Per Second",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 4
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "ops",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "blue"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(app_db_query_duration_seconds_count[1m])",
                    "legendFormat": "queries/sec"
                }
            ]
        },
        {
            "id": 4,
            "title": "Slow Queries (>100ms)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 12
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "ops",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "red"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(app_db_query_duration_seconds_count[1m]) - rate(app_db_query_duration_seconds_bucket{le=\"0.1\"}[1m])",
                    "legendFormat": "slow queries/sec (>100ms)"
                }
            ]
        },
        {
            "id": 5,
            "title": "MySQL Connections (mysqld_exporter)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 12
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "mysql_global_status_threads_connected",
                    "legendFormat": "Connected Threads"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "mysql_global_status_max_used_connections",
                    "legendFormat": "Max Used Connections"
                }
            ]
        },
        {
            "id": 6,
            "title": "MySQL Queries/sec (mysqld_exporter)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "ops",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(mysql_global_status_queries[1m])",
                    "legendFormat": "queries/sec"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(mysql_global_status_slow_queries[1m])",
                    "legendFormat": "slow queries/sec"
                }
            ]
        },
        {
            "id": 7,
            "title": "MySQL InnoDB Buffer Pool",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "mysql_global_status_innodb_buffer_pool_bytes_data",
                    "legendFormat": "Buffer Pool Data"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "mysql_global_status_innodb_buffer_pool_bytes_dirty",
                    "legendFormat": "Buffer Pool Dirty"
                }
            ]
        },
        {
            "id": 8,
            "title": "App vs DB Latency Comparison",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 28
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[1m])) by (le))",
                    "legendFormat": "p95 HTTP (total)"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, rate(app_db_query_duration_seconds_bucket[1m]))",
                    "legendFormat": "p95 DB query"
                }
            ]
        }
    ],
    "schemaVersion": 36
}
