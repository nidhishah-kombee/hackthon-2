{
    "uid": "health-dashboard",
    "title": "A. Application Health Dashboard",
    "tags": [
        "hackathon",
        "health"
    ],
    "timezone": "browser",
    "refresh": "10s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "panels": [
        {
            "id": 1,
            "title": "Requests Per Minute",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqpm",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(app_http_requests_total[1m])) * 60",
                    "legendFormat": "req/min"
                }
            ]
        },
        {
            "id": 2,
            "title": "Error Rate %",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "red"
                    },
                    "max": 100
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(app_http_requests_total{status=~\"5..\"}[1m])) / sum(rate(app_http_requests_total[1m])) * 100",
                    "legendFormat": "Error %"
                }
            ]
        },
        {
            "id": 3,
            "title": "p95 / p50 Latency",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[1m])) by (le))",
                    "legendFormat": "p95"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.50, sum(rate(app_http_request_duration_seconds_bucket[1m])) by (le))",
                    "legendFormat": "p50"
                }
            ]
        },
        {
            "id": 4,
            "title": "Active Users Over Time",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "green"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "app_active_users_total",
                    "legendFormat": "Active Users"
                }
            ]
        },
        {
            "id": 5,
            "title": "Slowest Endpoints (avg latency)",
            "type": "bargauge",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {
                        "mode": "continuous-RdYlGr"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.1
                            },
                            {
                                "color": "orange",
                                "value": 0.5
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    }
                }
            },
            "options": {
                "orientation": "horizontal",
                "displayMode": "gradient",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "showUnfilled": true,
                "text": {
                    "titleSize": 12,
                    "valueSize": 14
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sort_desc(sum by (route) (rate(app_http_request_duration_seconds_sum{route!~\"api/anomaly.*|sanctum/csrf-cookie|unknown\"}[5m])) / sum by (route) (rate(app_http_request_duration_seconds_count{route!~\"api/anomaly.*|sanctum/csrf-cookie|unknown\"}[5m])))",
                    "legendFormat": "{{route}}",
                    "instant": true
                }
            ]
        },
        {
            "id": 6,
            "title": "Requests by Route",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(app_http_requests_total{route!~\"api/anomaly.*|sanctum/csrf-cookie|unknown|metrics\"}[1m])) by (route)",
                    "legendFormat": "{{route}}"
                }
            ]
        },
        {
            "id": 7,
            "title": "Active Users (now)",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 4,
                "x": 0,
                "y": 24
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "green"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "app_active_users_total",
                    "legendFormat": "Users",
                    "instant": true
                }
            ]
        },
        {
            "id": 8,
            "title": "Total Requests",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 4,
                "x": 4,
                "y": 24
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(app_http_requests_total)",
                    "legendFormat": "Total",
                    "instant": true
                }
            ]
        },
        {
            "id": 9,
            "title": "Total 5xx Errors",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 4,
                "x": 8,
                "y": 24
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "red"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(app_http_requests_total{status=~\"5..\"})",
                    "legendFormat": "5xx",
                    "instant": true
                }
            ]
        },
        {
            "id": 10,
            "title": "p95 Latency (now)",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 4,
                "x": 12,
                "y": 24
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "orange"
                    }
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "p95",
                    "instant": true
                }
            ]
        }
    ],
    "schemaVersion": 36
}
