{
  "title": "Hackathon Observability — Full Stack",
  "uid": "hackathon-main",
  "tags": [
    "laravel",
    "hackathon"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 36,
  "version": 3,
  "panels": [
    {
      "id": 1,
      "title": "Requests Per Minute",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(app_http_requests_total[1m])) * 60",
          "legendFormat": "req/min"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(app_http_requests_total{status=~\"5..\"}[1m])) / sum(rate(app_http_requests_total[1m])) * 100",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 / p50 Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(app_http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Users",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "app_active_users_total",
          "legendFormat": "Active Users",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 21,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(app_http_requests_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total 5xx Errors",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 3,
        "x": 18,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(app_http_errors_total)",
          "legendFormat": "5xx",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Slowest Endpoints (avg latency)",
      "type": "bargauge",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "continuous-RdYlGr"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true,
        "text": {
          "titleSize": 12,
          "valueSize": 14
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sort_desc(sum by (route) (rate(app_http_request_duration_seconds_sum{route!~\"api/anomaly.*|sanctum/csrf-cookie|unknown\"}[5m])) / sum by (route) (rate(app_http_request_duration_seconds_count{route!~\"api/anomaly.*|sanctum/csrf-cookie|unknown\"}[5m])))",
          "legendFormat": "{{route}}",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Requests by Route",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (route) (rate(app_http_requests_total{route!~\"api/anomaly.*|sanctum/csrf-cookie|unknown|metrics\"}[1m])) * 60",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "DB Query Latency (p95 / p50)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(app_db_query_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p95 DB"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(app_db_query_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p50 DB"
        }
      ]
    },
    {
      "id": 10,
      "title": "DB Queries Per Minute",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(app_db_query_duration_seconds_count[1m])) * 60",
          "legendFormat": "Queries/min"
        }
      ]
    },
    {
      "id": 11,
      "title": "Slow Queries (>100ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(app_db_query_duration_seconds_bucket{le=\"+Inf\"}[1m]) - rate(app_db_query_duration_seconds_bucket{le=\"0.1\"}[1m])) * 60",
          "legendFormat": "Slow Queries/min"
        }
      ]
    },
    {
      "id": 12,
      "title": "MySQL — Queries Per Second",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(mysql_global_status_queries[1m])",
          "legendFormat": "Queries/sec"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(mysql_global_status_slow_queries[1m])",
          "legendFormat": "Slow Queries/sec"
        }
      ]
    },
    {
      "id": 13,
      "title": "MySQL — Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "mysql_global_status_threads_connected",
          "legendFormat": "Connected"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "mysql_global_status_max_used_connections",
          "legendFormat": "Max Used"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "mysql_global_variables_max_connections",
          "legendFormat": "Max Allowed"
        }
      ]
    },
    {
      "id": 14,
      "title": "MySQL — InnoDB Buffer Pool",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "mysql_global_status_innodb_buffer_pool_bytes_data",
          "legendFormat": "Data"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "mysql_global_status_innodb_buffer_pool_bytes_dirty",
          "legendFormat": "Dirty"
        }
      ]
    },
    {
      "id": 15,
      "title": "MySQL — Aborted Connections",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "mysql_global_status_aborted_connects",
          "legendFormat": "Aborted"
        }
      ]
    },
    {
      "id": 16,
      "title": "MySQL — Table Locks",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 9,
        "x": 6,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(mysql_global_status_table_locks_waited[1m])",
          "legendFormat": "Locks Waited/sec"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(mysql_global_status_table_locks_immediate[1m])",
          "legendFormat": "Locks Immediate/sec"
        }
      ]
    },
    {
      "id": 17,
      "title": "MySQL — Network Traffic",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 9,
        "x": 15,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(mysql_global_status_bytes_received[1m])",
          "legendFormat": "Received"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(mysql_global_status_bytes_sent[1m])",
          "legendFormat": "Sent"
        }
      ]
    },
    {
      "id": 18,
      "title": "Application Logs (All)",
      "type": "logs",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"laravel\"} | json"
        }
      ]
    },
    {
      "id": 19,
      "title": "Error Logs",
      "type": "logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 45
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"laravel\"} | json | level_name=~\"ERROR|CRITICAL|ALERT|EMERGENCY\""
        }
      ]
    },
    {
      "id": 20,
      "title": "Login Failures",
      "type": "logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 45
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"laravel\"} | json | message=~\"Login failed.*\""
        }
      ]
    },
    {
      "id": 21,
      "title": "Slow Query Logs",
      "type": "logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 55
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"laravel\"} | json | message=~\"Slow query.*\""
        }
      ]
    },
    {
      "id": 22,
      "title": "Log Count by Level",
      "type": "timeseries",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 55
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (level_name) (count_over_time({job=\"laravel\"} | json | __error__=\"\" [1m]))",
          "legendFormat": "{{level_name}}"
        }
      ]
    },
    {
      "id": 23,
      "title": "Activity Log — Events Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 65
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (log_name) (count_over_time({job=\"laravel\"} | json | message=~\".*created|.*updated|.*deleted\" [1m]))",
          "legendFormat": "{{log_name}}"
        }
      ]
    },
    {
      "id": 24,
      "title": "Activity Log — Recent Entries",
      "type": "logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 65
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"laravel\"} | json | message=~\".*created|.*updated|.*deleted\""
        }
      ]
    },
    {
      "id": 25,
      "title": "Trace Explorer",
      "type": "traces",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 75
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{.service.name=\"hackathon-app\"}"
        }
      ]
    }
  ]
}
